;;;
;;; sil-observation.theory version 001
;;;
;;; Derived from GIL observation_005.theory.
;;; Replaces visual/auditory/haptic detectors with computational detectors.
;;; Removes spatial mapping (Locater/Mapper).
;;; Retains all domain-independent services (Assimilator, Accommodator,
;;; Storer, Retriever, Matcher, Activator, Lexer).
;;;
;;; Patterns:   Mind/Body · Observation · Reminding
;;;
;;; Services:
;;;   Registrar · Perceiver · Executor · Assimilator · Accommodator
;;;   Lexer · Lexer2
;;;   StructureDetector · CodeDetector · MetricDetector
;;;   ErrorDetector · TextDetector · TemporalDetector
;;;   Storer · Retriever · Matcher · Activator
;;;
;;; Agents:
;;;   none  (Psyche runs on the Device as Python firmware)
;;;
;;; Timing:
;;;   @m160  ≈ 5 sec  (Psyche poll interval — external)
;;;


(module SIL-Observation


  ; ─────────────────────────────────────────────────────────────
  ; §1  MIND/BODY PATTERN
  ; ─────────────────────────────────────────────────────────────

  ; REGISTRAR — reactive service
  ; Receives [REGISTER ...] from the Psyche.
  ; Issues token and Executor/Perceiver URLs.

  (service Registrar
    "https://localhost/mind/registrar"
    (function {?sender ?msg}
      (var ?tok (uuid))
      (new Device
        :Name       (:Name ?msg)
        :Type       (:Type ?msg)
        :Address    ?sender
        :Needs      (:Needs ?msg)
        :Actuations (:Actuations ?msg)
        :Token      ?tok
        :Executor   "https://localhost:2010/minds/SIL"
        :Perceiver  "https://localhost:2025/minds/SIL")
      ; Create Need records for each homeostatic variable
      (for ?need in (:Needs ?msg)
        (knew Need :Name ?need :M (lexify ?need) :Delta 0))
      (tell ?sender
        [REGISTRATION
          :Status  Granted
          :Token   ?tok
          :Access  [URLS :Executor  "https://localhost:2010/minds/SIL"
                         :Perceiver "https://localhost:2025/minds/SIL"]])))


  ; PERCEIVER — reactive service
  ; Receives [PERCEPT ...], [URGE ...], or [RESULT ...] from Psyche.
  ; Creates corresponding records.  Dispatches to detectors.

  (service Perceiver
    "https://localhost/mind/perceiver"
    (function {?sender ?msg}
      (var ?now (moment))
      (case (:type ?msg)
        of Percept
          (var ?p
            (new Percept
              :Modality (:Modality ?msg)
              :Channel  (:Channel  ?msg)
              :Address  (:Address  ?msg)
              :Data     (:Data     ?msg)
              :Content  (:Content  ?msg)
              :Moment   ?now))
          ; Dispatch to appropriate detector based on modality
          (case (:Modality ?msg)
            of Textual    (tell "https://localhost/mind/text-detector"    [DETECT :Percept ?p])
            of Tabular    (tell "https://localhost/mind/struct-detector"  [DETECT :Percept ?p])
            of Metric     (tell "https://localhost/mind/metric-detector"  [DETECT :Percept ?p])
            of Diagnostic (tell "https://localhost/mind/error-detector"   [DETECT :Percept ?p])
            of Structural (tell "https://localhost/mind/struct-detector"  [DETECT :Percept ?p])
            of Temporal   (tell "https://localhost/mind/temporal-detector" [DETECT :Percept ?p]))
        of Urge
          (new Urge
            :M      (lexify (:Need ?msg))
            :Need   (:Need  ?msg)
            :Delta  (:Delta ?msg)
            :Moment ?now)
        of Result
          (new Result
            :Action (:Action ?msg)
            :Status (:Status ?msg)
            :Moment ?now))
      told))


  ; EXECUTOR — reactive service
  ; Forwards actuation requests to the Device via its Psyche address.

  (service Executor
    "https://localhost/mind/executor"
    (function {?sender ?msg}
      (with [Device :Address as ?addr :Token as ?tok]
        do
        (ask ?addr
          [ATTEMPT
            :Action     (:Action     ?msg)
            :Parameters (:Parameters ?msg)
            :Token      ?tok
            :By         (:By ?msg)])
        (with [Attempt :Action = (:Action ?msg) :Status = Pending as ?a]
          do (set ?a :Status Sent)))
      told))


  ; ─────────────────────────────────────────────────────────────
  ; §2  OBSERVATION PATTERN — COMPUTATIONAL DETECTORS
  ; ─────────────────────────────────────────────────────────────

  ; STRUCTURE DETECTOR — scans filesystem and tabular percepts
  ; Recognizes Datasets: format, rows, columns, language, labels.

  (service StructureDetector
    "https://localhost/mind/struct-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?traits {})
      (var ?content (:Content ?p))
      ; Extract dataset traits if CSV/JSON structure present
      (when (thing-p ?content)
        (when (:Rows ?content)
          (var ?ds (new Dataset
            :M        (reifier)
            :Format   (default (:Format ?content) csv)
            :Rows     (:Rows ?content)
            :Columns  (default (:Columns ?content) {})
            :Language (default (:Language ?content) nil)
            :HasLabels (default (:HasLabels ?content) no)))
          (enq ?traits (:M ?ds))
          ; Add size traits
          (if (> (:Rows ?content) 5000)
            (enq ?traits (lexify large-dataset))
            or (> (:Rows ?content) 500)
            (enq ?traits (lexify medium-dataset))
            else
            (enq ?traits (lexify small-dataset)))
          ; Add format trait
          (enq ?traits (lexify (:Format ?content)))
          ; Add label trait
          (when (= (:HasLabels ?content) yes)
            (enq ?traits (lexify training-data-available)))))
      ; Store in associative memory
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/storer"
          (store :Relation Percept :Content (reifier) :Traits ?traits))
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; CODE DETECTOR — scans source code percepts
  ; Recognizes CodePatterns: imports, algorithms, structural patterns.

  (service CodeDetector
    "https://localhost/mind/code-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?source (default (:Data ?p) ""))
      (var ?traits {})
      ; Detect code patterns by keyword presence
      (when (contains ?source "TfidfVectorizer")   (enq ?traits (lexify tfidf-approach)))
      (when (contains ?source "import sklearn")    (enq ?traits (lexify uses-sklearn)))
      (when (contains ?source "import openai")     (enq ?traits (lexify uses-llm-api)))
      (when (contains ?source "import anthropic")  (enq ?traits (lexify uses-llm-api)))
      (when (contains ?source "SVC")               (enq ?traits (lexify svm-classifier)))
      (when (contains ?source "RandomForest")      (enq ?traits (lexify random-forest)))
      (when (contains ?source "iterrows")          (enq ?traits (lexify row-by-row-inference)))
      (when (contains ?source "batch")             (enq ?traits (lexify batch-inference)))
      (when (contains ?source "train_test_split")  (enq ?traits (lexify uses-validation-split)))
      (when (contains ?source "try:")              (enq ?traits (lexify has-error-handling)))
      ; Classify approach category
      (if (or (in (lexify uses-sklearn) ?traits)
              (in (lexify tfidf-approach) ?traits))
        (enq ?traits (lexify uses-classical-ml))
        or (in (lexify uses-llm-api) ?traits)
        (enq ?traits (lexify uses-llm)))
      ; Store pattern records
      (for ?t in ?traits
        (new CodePattern :M ?t :Pattern (label ?t) :Source (:Address ?p)))
      ; Activate traits
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; METRIC DETECTOR — scans evaluation results
  ; Recognizes ScoreProfiles: metric, value, baseline, target, gap.

  (service MetricDetector
    "https://localhost/mind/metric-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?content (:Content ?p))
      (var ?traits {})
      (when (thing-p ?content)
        (var ?score  (default (:Accuracy ?content) (:Data ?p)))
        (var ?target (with [Registry :Key AccuracyTargetDefault :Value as ?v] give (/ ?v 100)))
        (when (thing-p ?score)
          (var ?sp (new ScoreProfile
            :M        (reifier)
            :Metric   accuracy
            :Value    ?score
            :Baseline 0
            :Target   ?target
            :Gap      (- ?target ?score)))
          (enq ?traits (:M ?sp))
          ; Categorize score
          (if (< ?score 0.10)  (enq ?traits (lexify accuracy-very-low))
            or (< ?score 0.50) (enq ?traits (lexify accuracy-below-half))
            or (>= ?score ?target) (enq ?traits (lexify accuracy-target-met))
            else (enq ?traits (lexify accuracy-moderate)))
          ; Create Urge proportional to gap
          (var ?gap (- ?target ?score))
          (when (> ?gap 0)
            (new Urge :M (lexify Accuracy) :Need Accuracy :Delta ?gap :Moment (moment)))))
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; ERROR DETECTOR — scans diagnostic percepts
  ; Recognizes ErrorSignatures: type, message, recoverability.

  (service ErrorDetector
    "https://localhost/mind/error-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?data    (default (:Data ?p) ""))
      (var ?content (:Content ?p))
      (var ?traits  {})
      ; Classify error type
      (var ?exit-code (default (:ExitCode ?content) 0))
      (when (/= ?exit-code 0)
        (enq ?traits (lexify crashed))
        (var ?err-type crash)
        (var ?recoverable no)
        ; Refine error type from message
        (when (contains ?data "ModuleNotFoundError")
          (var ?err-type missing-dep)
          (var ?recoverable yes)
          (enq ?traits (lexify missing-dependency)))
        (when (contains ?data "Rate limit")
          (var ?err-type rate-limit)
          (var ?recoverable yes)
          (enq ?traits (lexify rate-limited)))
        (when (contains ?data "Timeout")
          (var ?err-type timeout)
          (var ?recoverable no)
          (enq ?traits (lexify timed-out)))
        (when (contains ?data "MemoryError")
          (var ?err-type memory-exhausted)
          (var ?recoverable no)
          (enq ?traits (lexify memory-exhausted)))
        (new ErrorSignature
          :M           (reifier)
          :Type        ?err-type
          :Message     ?data
          :Recoverable ?recoverable))
      ; Clean execution
      (when (= ?exit-code 0)
        (enq ?traits (lexify clean-execution)))
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; TEXT DETECTOR — scans task descriptions
  ; Extracts structural traits: problem type, data type, constraints.

  (service TextDetector
    "https://localhost/mind/text-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?text (default (:Data ?p) ""))
      (var ?traits {})
      ; Detect problem type
      (when (contains ?text "classification")   (enq ?traits (lexify classification)))
      (when (contains ?text "regression")       (enq ?traits (lexify regression)))
      (when (contains ?text "optimization")     (enq ?traits (lexify optimization)))
      (when (contains ?text "prediction")       (enq ?traits (lexify prediction)))
      (when (contains ?text "chess")            (enq ?traits (lexify board-game)))
      (when (contains ?text "knight")           (enq ?traits (lexify combinatorial-optimization)))
      (when (contains ?text "minimum moves")    (enq ?traits (lexify exact-integer-answer)))
      ; Detect data traits
      (when (contains ?text "Chinese")          (enq ?traits (lexify chinese-text)))
      (when (contains ?text "FEN")              (enq ?traits (lexify board-game-state)))
      (when (contains ?text "CSV")              (enq ?traits (lexify csv-format)))
      (when (contains ?text "JSON")             (enq ?traits (lexify json-format)))
      ; Detect constraints
      (when (contains ?text "accuracy")         (enq ?traits (lexify metric-accuracy)))
      (when (contains ?text "exact match")      (enq ?traits (lexify metric-exact-match)))
      ; Store and activate
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/storer"
          (store :Relation Percept :Content (reifier) :Traits ?traits))
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; TEMPORAL DETECTOR — scans timing percepts
  ; Recognizes duration profiles and latency patterns.

  (service TemporalDetector
    "https://localhost/mind/temporal-detector"
    (function {?sender ?msg}
      (var ?p (:Percept ?msg))
      (var ?seconds (default (:Data ?p) 0))
      (var ?traits {})
      (if (< ?seconds 60)   (enq ?traits (lexify fast-execution))
        or (< ?seconds 300) (enq ?traits (lexify moderate-execution))
        else                (enq ?traits (lexify slow-execution)))
      ; Budget urgency
      (with [Need :Name = Time-Budget :Delta as ?d]
        do (when (> ?d 0)
          (enq ?traits (lexify time-pressure))))
      (when (> (count ?traits) 0)
        (ask "https://localhost/mind/activator"
          (enable :Reifiers ?traits :Moment (moment))))
      [CASE :Relation Percept :Traits ?traits]))


  ; ─────────────────────────────────────────────────────────────
  ; §3  REMINDING PATTERN  (identical services from GIL)
  ; ─────────────────────────────────────────────────────────────

  ; STORER — indexes content in associative memory

  (service Storer
    "https://localhost/mind/storer"
    (function {?sender ?msg}
      (var ?cid (uuid))
      (new Case
        :Case     ?cid
        :R        (:Relation ?msg)
        :Content  (:Content  ?msg)
        :Traits   (:Traits   ?msg))
      (for ?t in (:Traits ?msg)
        (new Trait
          :Trait    ?t
          :R        (:Relation ?msg)
          :Case     ?cid))
      [CASE :Case ?cid]))


  ; RETRIEVER — fetches a Case by identifier

  (service Retriever
    "https://localhost/mind/retriever"
    (function {?sender ?msg}
      (with [Case :Case = (:Case ?msg) as ?c]
        give ?c)))


  ; MATCHER — Jaccard similarity search over Cases

  (service Matcher
    "https://localhost/mind/matcher"
    (function {?sender ?msg}
      (var ?probe   (:Traits   ?msg))
      (var ?reln    (:Relation ?msg))
      (var ?min     (default (:MinScore ?msg) 0.0))
      (var ?lim     (default (:Limit    ?msg) 10))
      (var ?retcase (= (:Return ?msg) Case))
      (var ?hits
        (with [Case :R = ?reln :Traits as ?ct :Case as ?ck :Content as ?cc]
          (>= (/ (count (intersect ?probe ?ct))
                 (count (union     ?probe ?ct))) ?min)
          list
          (on ?retcase
            [MATCH :Case    ?ck :Score (/ (count (intersect ?probe ?ct))
                                          (count (union     ?probe ?ct)))]
            [MATCH :Content ?cc :Score (/ (count (intersect ?probe ?ct))
                                          (count (union     ?probe ?ct)))])))
      (sort ?hits :Score desc :Limit ?lim)))


  ; ACTIVATOR — enables/impedes schemes in activative memory

  (service Activator
    "https://localhost/mind/activator"
    (function {?sender ?msg}
      (var ?vp (default (:Viewpoint ?msg) (GENERAL-AWARENESS)))
      (var ?rl (default (:Reality   ?msg) Observed))
      (var ?mo (:Moment ?msg))
      (case (:type ?msg)
        of enable
          (enable :reifiers (:Reifiers ?msg)
                  :moment   ?mo
                  :viewpoint ?vp
                  :reality  ?rl)
        of impede
          (impede :reifiers (:Reifiers ?msg)
                  :moment   ?mo
                  :viewpoint ?vp
                  :reality  ?rl))
      told))


  ; LEXER — maps labels to reifiers (Actual totality)

  (service Lexer
    "https://localhost/mind/lexer"
    (function {?sender ?msg}
      (case (:type ?msg)
        of lexify
          (var ?r
            (on (null-p (:Reifier ?msg))
                (make :Totality Actual)
                (:Reifier ?msg)))
          (new Lexeme
            :M        ?r
            :Totality Actual
            :Label    (:Label ?msg))
          [LEXEME :Reifier ?r]
        of label
          (with [Lexeme
                 :M        = (:Reifier ?msg)
                 :Totality = Actual
                 :Label    as ?lbl]
            give ?lbl))))


  ; ASSIMILATOR — creates schemes (identical to GIL)

  (service Assimilator
    "https://localhost/mind/assimilator"
    (function {?sender ?msg}
      (case (:type ?msg)
        of make
          (var ?r (make :relation  (default (:Relation  ?msg) nil)
                        :arguments (default (:Arguments ?msg) nil)
                        :referents (default (:Referents ?msg) nil)))
          [SCHEME :Reifier ?r]
        of join
          (var ?r (make :relation  (:Relation ?msg)
                        :arguments {(:Argument ?msg)}
                        :referents {(:Referent ?msg)}))
          [SCHEME :Reifier ?r])))


  ; ACCOMMODATOR — copies/modifies schemes (identical contract to GIL)

  (service Accommodator
    "https://localhost/mind/accommodator"
    (function {?sender ?msg}
      (case (:type ?msg)
        of copy
          (var ?source (with [S :M = (:Reifier ?msg) as ?s] give ?s))
          (when (null-p ?source) (return nil))
          (var ?new-args (union (difference (:A ?source) (default (:RemArgs ?msg) {}))
                                (default (:AddArgs ?msg) {})))
          (var ?new-refs (union (difference (:E ?source) (default (:RemRefs ?msg) {}))
                                (default (:AddRefs ?msg) {})))
          (var ?new-r (make :relation  (:R ?source)
                            :arguments ?new-args
                            :referents ?new-refs))
          [SCHEME :Reifier ?new-r]
        of edit
          (var ?source (with [S :M = (:Reifier ?msg) as ?s] give ?s))
          (when (null-p ?source) (return nil))
          (unless (void-p (:AddArgs ?msg))
            (set ?source :A (union (:A ?source) (:AddArgs ?msg))))
          (unless (void-p (:AddRefs ?msg))
            (set ?source :E (union (:E ?source) (:AddRefs ?msg))))
          [SCHEME :Reifier (:M ?source)])))


  ; observe — returns the set of SIL Observation mechanism expressions

  (function observe
    (inside
      (map
        {
          Activator Matcher Retriever Storer
          TemporalDetector ErrorDetector MetricDetector
          CodeDetector TextDetector StructureDetector
          Lexer Accommodator Assimilator
          Perceiver Registrar Executor
        }
        (given {?m} (call start ?m)))))


) ; end module SIL-Observation

;;; end theory SIL-Observation

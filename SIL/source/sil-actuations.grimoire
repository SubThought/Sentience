;;;
;;; sil-actuations.grimoire — Actuation definitions for the SIL Device
;;;
;;; The 12 actuations of the Computational Workbench.
;;; Each maps to one Premise intrinsic.
;;;
;;; These are the irreducible capabilities of SIL's body.
;;; Actions compose from actuations.  Actuations are never decomposed.
;;;

(grimoire SIL-Actuations


  ; ─────────────────────────────────────────────────────────────
  ; Shell Device
  ; ─────────────────────────────────────────────────────────────

  (schema Actuation { :Method %
    :Params {:Command nil} })
  (new Codes :M (lexify run-script)       :CodeSet Actuation :Memo "Execute a script via shell, return output + exit code")

  (schema Actuation { :Method %
    :Params {:Command "pip install"} })
  (new Codes :M (lexify install-package)  :CodeSet Actuation :Memo "Install a Python package via pip")

  (schema Actuation { :Method %
    :Params {:Command "python3 -m venv"} })
  (new Codes :M (lexify create-venv)      :CodeSet Actuation :Memo "Create a Python virtual environment")

  (schema Actuation { :Method %
    :Params {:Command "echo $"} })
  (new Codes :M (lexify read-env)         :CodeSet Actuation :Memo "Read an environment variable")


  ; ─────────────────────────────────────────────────────────────
  ; File System Device
  ; ─────────────────────────────────────────────────────────────

  (schema Actuation { :Method read
    :Params {:File nil} })
  (new Codes :M (lexify read-file)        :CodeSet Actuation :Memo "Read file contents")

  (schema Actuation { :Method write
    :Params {:File nil :Content nil} })
  (new Codes :M (lexify write-file)       :CodeSet Actuation :Memo "Write content to file")

  (schema Actuation { :Method %
    :Params {:Command "mkdir -p"} })
  (new Codes :M (lexify make-dir)         :CodeSet Actuation :Memo "Create directory recursively")

  (schema Actuation { :Method %
    :Params {:Command "cp"} })
  (new Codes :M (lexify copy-file)        :CodeSet Actuation :Memo "Copy a file")

  (schema Actuation { :Method erase
    :Params {:File nil} })
  (new Codes :M (lexify delete-file)      :CodeSet Actuation :Memo "Delete a file")


  ; ─────────────────────────────────────────────────────────────
  ; Network Device
  ; ─────────────────────────────────────────────────────────────

  (schema Actuation { :Method ask
    :Params {:Url nil :Body nil :Timeout 120} })
  (new Codes :M (lexify prompt-llm)       :CodeSet Actuation :Memo "Send prompt to LLM API, await response")


  ; ─────────────────────────────────────────────────────────────
  ; Encoding Device
  ; ─────────────────────────────────────────────────────────────

  (schema Actuation { :Method encode
    :Params {:Value nil :Format json} })
  (new Codes :M (lexify to-json)          :CodeSet Actuation :Memo "Serialize value to JSON string")

  (schema Actuation { :Method decode
    :Params {:String nil :Format json} })
  (new Codes :M (lexify from-json)        :CodeSet Actuation :Memo "Deserialize JSON string to value")


) ; end grimoire SIL-Actuations

;;;
;;; sil-reflection.theory version 001
;;;
;;; Derived from GIL reflection_005.theory.
;;; Timing rescaled for SIL computational domain.
;;; Ameliorator, Correlator, Regulator, Compensator, Simulator,
;;; Explorer, Evaluator, Aggregator, Attentor implemented.
;;;
;;; Patterns:   Motivation · Daydreaming · Regulation · Compensation ·
;;;             Coping · Exploration · Discovery · Meta-Control
;;;


(module SIL-Reflection


  ; ─────────────────────────────────────────────────────────────
  ; §1  MOTIVATION
  ; ─────────────────────────────────────────────────────────────

  ; AMELIORATOR — converts Urges to Objectives

  (agent Ameliorator
    (function {}
      (with [Urge :Delta as ?d :Need as ?need :M as ?urge-ref]
            (/= ?d 0)
        do
        (schema Objective
          { :Drive    life
            :Need     ?need
            :Context  {}
            :Goals    {}
            :Result   {(lexify ($ ?need -met))}
            :Priority (abs (* ?d 10))
            :Status   active
            :Moment   (moment)})))
    "https://localhost/mind/ameliorator"
    (function {?sender ?msg} told)
    \@m1500)


  ; SELECTOR — selects highest-priority Objective

  (agent Selector
    (function {}
      (var ?best nil)
      (var ?best-pri 0)
      (with [Objective :Status = active :Priority as ?pri as ?obj]
        do
        (when (> ?pri ?best-pri)
          (var ?best ?obj)
          (var ?best-pri ?pri)))
      (when (thing-p ?best)
        (enable :reifiers {(:M ?best)} :moment (moment) :reality Desired)))
    "https://localhost/mind/selector"
    (function {?sender ?msg} told)
    \@m1500)


  ; ─────────────────────────────────────────────────────────────
  ; §2  DAYDREAMING
  ; ─────────────────────────────────────────────────────────────

  ; SUPERVISOR — decides when to daydream

  (agent Supervisor
    (function {}
      (var ?active  (tally [Trial :Status = Executing]))
      (var ?pending (tally [Trial :Status = Pending]))
      (with [Simulation as ?sim]
        do
        (on (and (= ?active 0) (= ?pending 0))
          (set ?sim :Status running)
          (set ?sim :Status suspended))))
    "https://localhost/mind/supervisor"
    (function {?sender ?msg} told)
    \@m6000)


  ; SIMULATOR — creates forward Situations in Imagined reality

  (agent Simulator
    (function {}
      (var ?max-canvases
        (with [Registry :Key MaxConcurrentCanvases :Value as ?v] give ?v))
      (var ?current-canvases (tally [Canvas :Status = simulating]))
      (when (< ?current-canvases ?max-canvases)
        ; Find an active objective
        (with [Objective :Status = active :Result as ?desired as ?obj]
          do
          ; Find Actions toward this objective
          (with [S :R = (lexify Action) :M as ?act-ref :E as ?result-refs]
                (> (count (intersect ?result-refs ?desired)) 0)
            do
            ; Create a Canvas for this scenario
            (var ?canvas (new Canvas :M (reifier)
              :Label    ($ what-if (label ?act-ref))
              :Status   simulating
              :Moment   (moment)))
            (new Taxis
              :Canvas   (:M ?canvas)
              :Action   ?act-ref
              :Objective (:M ?obj)
              :Constraints {})
            ; Activate predicted result in Imagined reality (NOT Expected)
            (enable :reifiers ?result-refs :moment (moment) :reality Imagined)
            (set ?canvas :Status concluded)))))
    "https://localhost/mind/simulator"
    (function {?sender ?msg} told)
    \@m3000)


  ; INHIBITOR — gates execution during simulation

  (agent Inhibitor
    (function {} tbd)
    "https://localhost/mind/inhibitor"
    (function {?sender ?msg} told)
    \@m300)


  ; ─────────────────────────────────────────────────────────────
  ; §3  REGULATION
  ; ─────────────────────────────────────────────────────────────

  ; CORRELATOR — matches Results to Trials, creates Rewards

  (agent Correlator
    (function {}
      (with [Result  :Action as ?act :Status as ?status]
            [Trial   :Status = Executing :Action as ?trial-act as ?trial]
            [Utility :M = ?trial-act as ?u]
            (= ?act ?trial-act)
        do
        (set ?u :Attempts (+ (:Attempts ?u) 1))
        (if (= ?status Done)
          (set ?trial :Status Done)
          (set ?u :Successes (+ (:Successes ?u) 1))
          (new Reward
            :Attempt  ?trial
            :Action   ?act
            :Value    1
            :Moment   (moment))
          else
          (set ?trial :Status Failed)
          (new Reward
            :Attempt  ?trial
            :Action   ?act
            :Value    -1
            :Moment   (moment))))
      ; Resolve pending Predictions
      (with [Prediction :Outcome = pending :Deadline as ?dl :Hypothesis as ?hyp as ?pred]
        do
        (if (> (moment) ?dl)
          (set ?pred :Outcome failed))))
    "https://localhost/mind/correlator"
    (function {?sender ?msg} told)
    \@m900)


  ; TERMINATOR — detects Objective achievement

  (agent Terminator
    (function {}
      (with [Objective :Result as ?desired :Status = active as ?obj ^ as ?oid]
            [Happening :Schemes as ?current]
            (subset-p ?desired ?current)
        do
        (new Achieved :Objective ?oid :Happening (lexify Happening) :Moment (moment))
        (set ?obj :Status suspended)))
    "https://localhost/mind/terminator"
    (function {?sender ?msg} told)
    \@m300)


  ; REGULATOR — processes Rewards, reinforces/corrects Actions

  (agent Regulator
    (function {}
      (with [Reward :Action as ?act :Value as ?v as ?reward]
        do
        (with [Utility :M = ?act as ?u]
          do
          (on (> ?v 0)
            (set ?u :Successes (+ (:Successes ?u) 1))
            (set ?u :Attempts  (+ (:Attempts  ?u) 1))))
        ; Create Lesson on significant success
        (when (> ?v 0)
          (with [Objective :Status = active as ?obj]
            do
            (schema Lesson
              { :Problem  (:M ?obj)
                :Solution ?act
                :Outcome  succeeded })))
        (old ?reward)))
    "https://localhost/mind/regulator"
    (function {?sender ?msg} told)
    \@m1500)


  ; ─────────────────────────────────────────────────────────────
  ; §4  COMPENSATION
  ; ─────────────────────────────────────────────────────────────

  ; COMPENSATOR — modifies Objectives in response to failure

  (agent Compensator
    (function {}
      (with [Reward :Action as ?act :Objective as ?obj :Value as ?v as ?reward]
        do
        (if (< ?v 0)
          ; Negative — create new Objective to try alternative
          (schema Objective
            { :Drive    life
              :Need     nil
              :Context  {}
              :Goals    {}
              :Result   {(lexify alternative-approach-needed)}
              :Priority 8
              :Status   active
              :Moment   (moment)})
          ; Create Obstacle record
          (schema Obstacle
            { :Before   {}
              :During   {?act}
              :Expected {}
              :Actual   {(lexify execution-failed)} })
          or (> ?v 0)
          ; Positive — reinforce the approach
          (with [Objective ^ = ?obj as ?o]
            do (set ?o :Priority (+ (:Priority ?o) 1))))
        (old ?reward)))
    "https://localhost/mind/compensator"
    (function {?sender ?msg} told)
    \@m1200)


  ; ─────────────────────────────────────────────────────────────
  ; §5  COPING
  ; ─────────────────────────────────────────────────────────────

  (agent Evaluator
    (function {}
      (with [Activation :Reality = Desired :Pulses as ?p :M as ?obj-ref]
            (> ?p 0)
        do
        (var ?done  (tally [Trial :Status = Done]))
        (var ?total (max 1 (tally [Trial])))
        (new Appraisal
          :Objective  ?obj-ref
          :Valence    (- (* (/ ?done ?total) 2) 1)
          :Arousal    (arousal-for ?obj-ref)
          :Likelihood (/ ?done ?total)
          :Moment     (moment))))
    "https://localhost/mind/evaluator"
    (function {?sender ?msg} told)
    \@m2250)


  (agent Aggregator
    (function {}
      (var ?window 15000)
      (var ?now    (moment))
      (var ?apprs
        (with [Appraisal :Moment as ?t as ?a]
              (< (- ?now ?t) ?window)
          list ?a))
      (when (> (count ?apprs) 0)
        (new Affect
          :Appraisals ?apprs
          :Valence    (/ (sum (map ?apprs ?a (:Valence ?a))) (count ?apprs))
          :Arousal    (/ (sum (map ?apprs ?a (:Arousal ?a))) (count ?apprs))
          :Moment     ?now)))
    "https://localhost/mind/aggregator"
    (function {?sender ?msg} told)
    \@m3000)


  (agent Attentor
    (function {}
      (with [Affect :Valence as ?v :Arousal as ?a]
            (and (< ?v 0) (> ?a 0))
        do
        (new Response
          :Appraisal    (this)
          :Emotion      distress
          :CopingMethod solve)))
    "https://localhost/mind/attentor"
    (function {?sender ?msg} told)
    \@m4500)


  ; ─────────────────────────────────────────────────────────────
  ; §6  EXPLORATION
  ; ─────────────────────────────────────────────────────────────

  ; EXPLORER — tries Actions with unknown postconditions

  (agent Explorer
    (function {}
      (var ?explore-pct
        (with [Registry :Key ExplorationProbability :Value as ?v] give ?v))
      ; Random exploration gate
      (when (< (rand 100) ?explore-pct)
        (with [S :R = (lexify Action) :M as ?act-ref :E as ?refs]
              (void-p ?refs)
              (= 0 (tally [Trial :Action = ?act-ref]))
          do
          (new Experience :Action ?act-ref :Start (moment) :End 0 :Status running)
          (new Trial :Action ?act-ref :Status Pending :Moment (moment)))))
    "https://localhost/mind/explorer"
    (function {?sender ?msg} told)
    \@m6000)


  ; ELABORATOR — assesses system changes during Experience

  (agent Elaborator
    (function {}
      (with [Experience :Status = running :Action as ?act :Start as ?t0 as ?exp]
            [Trial :Status = Done :Action as ?trial-act]
            (= ?act ?trial-act)
        do
        (set ?exp :End (moment) :Status done)
        (var ?delta (difference (active-reifiers Observed) (active-reifiers-at ?t0)))
        (when (not (void-p ?delta))
          (ask "https://localhost/mind/accommodator"
            (copy :Reifier ?act :AddRefs ?delta)))
        (old ?exp)))
    "https://localhost/mind/elaborator"
    (function {?sender ?msg} told)
    \@m1500)


  ; ─────────────────────────────────────────────────────────────
  ; §7  DISCOVERY  (stubs)
  ; ─────────────────────────────────────────────────────────────

  (agent Ascriber    (function {} tbd) "https://localhost/mind/ascriber"    (function {?sender ?msg} told) \@m9000)
  (agent Predictor   (function {} tbd) "https://localhost/mind/predictor"   (function {?sender ?msg} told) \@m1500)
  (agent Designer    (function {} tbd) "https://localhost/mind/designer"    (function {?sender ?msg} told) \@m12000)
  (agent Experimenter(function {} tbd) "https://localhost/mind/experimenter"(function {?sender ?msg} told) \@m9000)


  ; ─────────────────────────────────────────────────────────────
  ; §8  IMITATION, PLAY, META-CONTROL  (stubs)
  ; ─────────────────────────────────────────────────────────────

  (agent Recognizer (function {} tbd) "https://localhost/mind/recognizer" (function {?sender ?msg} told) \@m1900)
  (agent Reproducer (function {} tbd) "https://localhost/mind/reproducer" (function {?sender ?msg} told) \@m1500)
  (agent Composer   (function {} tbd) "https://localhost/mind/composer"   (function {?sender ?msg} told) \@m6000)
  (agent Practicer  (function {} tbd) "https://localhost/mind/practicer"  (function {?sender ?msg} told) \@m6000)
  (agent Monitor    (function {} tbd) "https://localhost/mind/monitor"    (function {?sender ?msg} told) \@m15000)
  (agent Modifier   (function {} tbd) "https://localhost/mind/modifier"   (function {?sender ?msg} told) \@m15000)


  ; reflect — returns SIL Reflection mechanism set

  (function reflect
    (inside
      (map
        {
          Ameliorator Selector
          Supervisor Simulator Inhibitor
          Correlator Regulator Terminator
          Compensator
          Evaluator Aggregator Attentor
          Explorer Elaborator
          Ascriber Predictor Designer Experimenter
          Recognizer Reproducer
          Composer Practicer
          Monitor Modifier
        }
        (given {?m} (call start ?m)))))


) ; end module SIL-Reflection

;;; end theory SIL-Reflection

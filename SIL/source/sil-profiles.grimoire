;;;
;;; sil-profiles.grimoire — LLM Provider and Profile definitions for SIL
;;;
;;; Providers define LLM API endpoints.
;;; Profiles define agent configurations (model + provider + parameters).
;;;
;;; These replace SIA's JSON profile and provider files.
;;; Mechanisms look up providers/profiles from the KB, not from files.
;;;

(grimoire SIL-Profiles


  ; ─────────────────────────────────────────────────────────────
  ; Providers — LLM API endpoints
  ; ─────────────────────────────────────────────────────────────

  (relation Provider
    :Id          nil    ; provider identifier symbol
    :Name        nil    ; human-readable name
    :ClientKind  nil    ; anthropic | openai | google
    :BaseUrl     nil    ; API base URL (nil = default for client kind)
    :ApiKeyEnv   nil    ; environment variable holding the API key
  )

  (new Provider :Id anthropic :Name Anthropic
    :ClientKind anthropic :BaseUrl nil :ApiKeyEnv ANTHROPIC_API_KEY)

  (new Provider :Id openai :Name OpenAI
    :ClientKind openai :BaseUrl nil :ApiKeyEnv OPENAI_API_KEY)

  (new Provider :Id nebius :Name Nebius
    :ClientKind openai :BaseUrl "https://api.studio.nebius.com/v1/"
    :ApiKeyEnv NEBIUS_API_KEY)

  (new Provider :Id tinker :Name Tinker
    :ClientKind openai :BaseUrl "https://text.pollinations.ai/openai"
    :ApiKeyEnv TINKER_API_KEY)

  (new Provider :Id together :Name Together
    :ClientKind openai :BaseUrl "https://api.together.xyz/v1/"
    :ApiKeyEnv TOGETHER_API_KEY)

  (new Provider :Id gemini :Name Gemini
    :ClientKind google :BaseUrl nil :ApiKeyEnv GOOGLE_API_KEY)


  ; ─────────────────────────────────────────────────────────────
  ; Profiles — agent configurations
  ; ─────────────────────────────────────────────────────────────

  (relation Profile
    :Id          nil    ; profile identifier symbol
    :Role        nil    ; meta | target | feedback
    :Model       nil    ; model name string
    :Provider    nil    ; provider identifier symbol
    :MaxTurns    1      ; max interaction turns
    :Temperature 0      ; sampling temperature (0 = deterministic)
  )

  ; Meta-agent profiles
  (new Profile :Id meta-sonnet :Role meta
    :Model "claude-sonnet-4-20250514" :Provider anthropic :MaxTurns 3)

  (new Profile :Id meta-haiku :Role meta
    :Model "claude-haiku-4-5-20251001" :Provider anthropic :MaxTurns 3)

  ; Target-agent profiles
  (new Profile :Id target-haiku :Role target
    :Model "claude-haiku-4-5-20251001" :Provider anthropic :MaxTurns 10)

  (new Profile :Id target-gpt :Role target
    :Model "openai/gpt-oss-120b" :Provider tinker :MaxTurns 5)

  (new Profile :Id target-gemini :Role target
    :Model "gemini-3.1-flash-lite-preview" :Provider gemini :MaxTurns 5)


) ; end grimoire SIL-Profiles
